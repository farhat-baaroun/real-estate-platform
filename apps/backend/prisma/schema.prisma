generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Listing {
  id        String   @id @default(cuid())
  title     String
  price     Float
  bedrooms  Int
  status    String   @default("draft")
  createdAt DateTime @default(now())
}

# Copy to `.env` and replace placeholders (never commit `.env`).

# --- Supabase Postgres --------------------------------------------------------
# Pooled connection (PgBouncer / transaction mode). Use for the app runtime.
# From Supabase: Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (session mode). Required for `prisma migrate` / `db push`.
# From Supabase: use port 5432 “direct” / session connection string.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# --- SuperTokens (backend) --------------------------------------------------
SUPERTOKENS_CONNECTION_URI=""
SUPERTOKENS_API_KEY=""

# Optional strict domains in production (see `src/auth/supertokens.ts`)
# API_DOMAIN="https://api.example.com"
# WEBSITE_DOMAIN="https://app.example.com"

# CORS: in production, comma-separated allowed origins; dev uses open CORS (see `src/server.ts`)
# CORS_ALLOWED_ORIGINS="https://app.example.com,https://www.example.com"

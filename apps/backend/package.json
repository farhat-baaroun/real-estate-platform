{
  "name": "@real-estate/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"src/generated/**\"",
    "typecheck": "prisma generate && pnpm --filter @real-estate/domain build && tsc --noEmit -p tsconfig.json",
    "test": "pnpm --filter @real-estate/domain build && prisma db push --accept-data-loss && vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.19.3",
    "@real-estate/domain": "workspace:*",
    "fastify": "^5.0.0",
    "supertokens-node": "^24.0.2",
    "temporal-polyfill": "^0.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5",
    "prisma": "^6.19.3"
  }
}

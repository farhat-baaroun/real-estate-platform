{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug (tsx)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect-brk",
        "--import",
        "tsx",
        "apps/backend/src/index.ts"
      ],
      "envFile": "${workspaceFolder}/apps/backend/.env",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
